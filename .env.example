# Wildlife Watcher Mobile App - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key (backend only - DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# GOOGLE MAPS API KEYS
# =============================================================================
# Get these from: Google Cloud Console → APIs & Services → Credentials
# IMPORTANT: Restrict keys by bundle ID/package name in production
GOOGLE_MAPS_API_KEY_ANDROID=your_android_maps_api_key_here
GOOGLE_MAPS_API_KEY_IOS=your_ios_maps_api_key_here

# Client-side variants (if needed)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=your_android_maps_api_key_here
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=your_ios_maps_api_key_here

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Base URL for Wildlife Watcher API
API_BASE=https://api.wildlifewatcher.com
EXPO_PUBLIC_API_BASE=https://api.wildlifewatcher.com

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# - EXPO_PUBLIC_ prefixed variables are accessible in client-side code
# - Non-prefixed variables are only available in server-side/build contexts
# - This file (.env.example) is committed to git as a template
# - Your actual .env.local file is excluded from git
# - Bundle identifiers are configured in app.config.js, not here
# - URL schemes are configured in app.config.js, not here

# =============================================================================
# EAS BUILD CONFIGURATION
# =============================================================================
# Path to Google Play Service Account JSON key (required for --auto-submit)
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=XXXXXX
# For EAS builds, secrets must be configured using EAS Secrets
# See: project-context/development-context/MVP2/implementation/execution/db-environment-switching-in-app/EAS-SECRETS-SETUP.md
# Run: eas secret:create --scope project --name VAR_NAME --value "your_value" --type string
APPLE_ID=XXXXX
ASC_APP_ID=XXXX
APPLE_TEAM_ID=XXXX