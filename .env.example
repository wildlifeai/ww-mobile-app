# Wildlife Watcher Mobile App - Environment Variables Template
# Copy this file to .env.local and fill in your actual values:
#   cp .env.example .env.local
#
# .env.local is gitignored — DO NOT commit it.
# For EAS cloud builds, secrets are set via `eas secret:create`.

# ─── Supabase ──────────────────────────────────────────────────────
# Dev instance (qegeovogqxiouqbrxmnh) — default for local development
EXPO_PUBLIC_SUPABASE_URL=https://qegeovogqxiouqbrxmnh.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your_dev_anon_key>

# Staging instance (nuhwmubvygxyddkycmpa) — for pre-production validation
EXPO_PUBLIC_SUPABASE_STAGING_URL=https://nuhwmubvygxyddkycmpa.supabase.co
EXPO_PUBLIC_SUPABASE_STAGING_ANON_KEY=<your_staging_anon_key>

# Production instance — used by EAS production profile builds
# These are managed via EAS secrets (not committed to the repo).
# See: eas secret:list

# ─── Google Maps ───────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY_ANDROID=<your_google_maps_android_key>
GOOGLE_MAPS_API_KEY_IOS=<your_google_maps_ios_key>

# ─── App Variant ───────────────────────────────────────────────────
# Set to "development" for dev builds (adds .expo suffix to bundle ID)
APP_VARIANT=development

# ─── Notes ─────────────────────────────────────────────────────────
# EXPO_PUBLIC_ prefixed vars are accessible in client-side code
# Non-prefixed vars are only available at build time
# Bundle identifiers and URL schemes are in app.config.ts
# Store submission credentials (Apple ID, Google Play service account)
#   are in eas.json — see documentation/resources/publishing_guide.md