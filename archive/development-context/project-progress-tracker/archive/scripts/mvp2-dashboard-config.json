  "quality_gates": {
    "test_coverage": {
      "name": "Test Coverage",
      "description": "Minimum test coverage percentage for code quality",
      "threshold": 80,
      "threshold_type": "minimum",
      "measurement_unit": "percentage",
      "criticality": "high"
    },
    "typescript_errors": {
      "name": "TypeScript Errors",
      "description": "Zero tolerance for TypeScript compilation errors",
      "threshold": 0,
      "threshold_type": "maximum",
      "measurement_unit": "count",
      "criticality": "critical"
    },
    "build_status": {
      "name": "Build Status",
      "description": "Successful build compilation status",
      "threshold": "passing",
      "threshold_type": "exact",
      "measurement_unit": "status",
      "criticality": "critical"
    },
    "performance_budget": {
      "name": "Performance Budget",
      "description": "Application performance within acceptable limits",
      "threshold": "within_limits",
      "threshold_type": "exact",
      "measurement_unit": "status",
      "criticality": "high"
    },
    "security_scan": {
      "name": "Security Scan",
      "description": "No security vulnerabilities in dependencies",
      "threshold": "clean",
      "threshold_type": "exact",
      "measurement_unit": "status",
      "criticality": "high"
    },
    "dependency_audit": {
      "name": "Dependency Audit",
      "description": "All dependencies are secure and up-to-date",
      "threshold": "no_vulnerabilities",
      "threshold_type": "exact",
      "measurement_unit": "status",
      "criticality": "medium"
    }
  },
