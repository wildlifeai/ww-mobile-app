{
  "name": "wildlifewatcher",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "start": "npx expo start",
    "prebuild:check": "bash scripts/pre-build-check.sh",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=\"(src/.*\\.(test|spec)\\.(ts|tsx)$|tests/unit/)\"",
    "test:integration": "jest --testPathPattern=tests/integration/",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:maestro": "maestro test tests/maestro/",
    "test:maestro:auth": "maestro test tests/maestro/auth-workflow.yaml",
    "test:maestro:offline": "maestro test tests/maestro/offline/complete-offline-workflow.yaml",
    "type-check": "tsc --noEmit",
    "validate:deps": "node scripts/validate-deps.js",
    "deps": "node scripts/deps-cli.js",
    "deps:add": "node scripts/deps-cli.js add",
    "deps:scan": "node scripts/deps-cli.js scan",
    "types:local": "cd ~/dev/wildlifeai/wildlife-watcher-backend && npx supabase gen types typescript --local > ~/dev/wildlifeai/wildlife-watcher-mobile-app/src/types/supabase.ts",
    "types:cloud-dev": "npx supabase gen types typescript --project-id nuhwmubvygxyddkycmpa --schema public > src/types/database.types.ts",
    "types:cloud-prod": "echo '⚠️  Production project ref not yet configured' && exit 1",
    "types:check-local": "./scripts/check-types-local.sh",
    "types:check-cloud-dev": "./scripts/check-types-cloud.sh cloud-dev",
    "types:check-cloud-prod": "./scripts/check-types-cloud.sh cloud-prod",
    "validate:local": "./scripts/test-integration-local.sh",
    "validate:cloud-dev": "npm run types:check-cloud-dev && npm run type-check && npm test",
    "validate:cloud-prod": "npm run types:check-cloud-prod && npm run type-check && npm test",
    "prebuild:preview": "npm run validate:cloud-dev",
    "prebuild:production": "npm run validate:cloud-prod",
    "supabase:types": "echo 'Types are manually synced from backend repository. See src/types/supabase.ts'",
    "schema:validate": "node scripts/validate-watermelon-schema.js",
    "schema:validate:verbose": "node scripts/validate-watermelon-schema.js --verbose",
    "schema:validate:live": "node scripts/validate-watermelon-schema-live.js",
    "schema:validate:live:local": "node scripts/validate-watermelon-schema-live.js --env=local",
    "schema:validate:live:cloud-dev": "node scripts/validate-watermelon-schema-live.js --env=cloud-dev",
    "sync:from-live:cloud-dev": "npm run types:cloud-dev && npm run schema:validate:live:cloud-dev",
    "dev:status": "npm run types:check-local && npm run schema:validate:live:local",
    "postinstall": "npm run validate:deps"
  },
  "dependencies": {
    "@getquip/expo-nordic-dfu": "^2.0.3",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-navigation/native": "^6.1.12",
    "@react-navigation/native-stack": "^6.9.20",
    "@reduxjs/toolkit": "^2.5.0",
    "@supabase/supabase-js": "^2.53.0",
    "@types/lodash.isempty": "^4.4.9",
    "@types/uuid": "^10.0.0",
    "buffer": "^6.0.3",
    "dayjs": "^1.11.10",
    "deepmerge": "^4.3.1",
    "eventemitter3": "^5.0.1",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.15",
    "lodash.isempty": "^4.4.0",
    "react": "19.1.1",
    "react-hook-form": "^7.54.1",
    "react-native": "0.81.5",
    "react-native-ble-manager": "^11.3.2",
    "react-native-bluetooth-state-manager": "^1.3.5",
    "react-native-device-info": "^10.13.1",
    "react-native-document-picker": "^9.3.1",
    "react-native-drawer-layout": "^3.3.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-paper": "^5.12.3",
    "react-native-paper-dropdown": "^2.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.2.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-worklets": "^0.7.1",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@morrowdigital/watermelondb-expo-plugin": "^2.3.3",
    "@react-native-community/cli": "^20.0.2",
    "@react-native/babel-preset": "0.74.88",
    "@react-native/eslint-config": "0.74.88",
    "@react-native/metro-config": "0.74.88",
    "@react-native/typescript-config": "0.74.88",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.0.0",
    "babel-jest": "^29.6.3",
    "detox": "^20.19.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "jest-circus": "^29.6.3",
    "jest-environment-jsdom": "^30.1.1",
    "maestro": "^2.1.1",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.1",
    "redux-mock-store": "^1.5.5",
    "typescript": "~5.3.3"
  },
  "overrides": {},
  "engines": {
    "node": ">=18"
  }
}
